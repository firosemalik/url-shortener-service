{
  "info": {
    "name": "URL Shortener Service (Updated)",
    "_postman_id": "url-shortener-api-collection",
    "description": "Postman collection for testing the updated URL Shortener API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Short URL",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"originalUrl\": \"https://example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/urls",
          "host": ["{{baseUrl}}"],
          "path": ["urls"]
        }
      },
      "response": []
    },
    {
      "name": "Redirect to Original URL",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/urls/:code/redirect",
          "host": ["{{baseUrl}}"],
          "path": ["urls", ":code", "redirect"]
        }
      },
      "response": []
    },
    {
      "name": "Get URL Info",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/urls/:code",
          "host": ["{{baseUrl}}"],
          "path": ["urls", ":code"]
        }
      },
      "response": []
    },
    {
      "name": "Get Access Logs",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/urls/:code/access-logs?page=0&size=20",
          "host": ["{{baseUrl}}"],
          "path": ["urls", ":code", "access-logs"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "20" }
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8085" }
  ]
}
