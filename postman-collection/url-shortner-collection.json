{
  "info": {
    "name": "URL Shortener API",
    "_postman_id": "url-shortener-api-collection",
    "description": "Postman collection for testing the URL Shortener API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Shorten URL",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"originalUrl\": \"https://www.example.com/blog/post1\"\n}"
        },
        "url": {
          "raw": "http://localhost:8085/shortener/urls",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8085",
          "path": ["shortener", "urls"]
        }
      },
      "response": []
    },
    {
      "name": "Redirect Short URL",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "User-Agent",
            "value": "PostmanRuntime/7.29.2"
          },
          {
            "key": "Referer",
            "value": "https://www.example.com"
          }
        ],
        "url": {
          "raw": "http://localhost:8085/shortener/urls/{{shortCode}}/redirect",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8085",
          "path": ["shortener", "urls", "{{shortCode}}", "redirect"]
        }
      },
      "response": []
    },
    {
      "name": "Get URL Info",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8085/shortener/urls/{{shortCode}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8085",
          "path": ["shortener", "urls", "{{shortCode}}"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "10" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Access Logs",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8085/shortener/urls/{{shortCode}}/logs?page=0&size=10",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8085",
          "path": ["shortener", "urls", "{{shortCode}}", "logs"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "shortCode",
      "value": "abc123"
    }
  ]
}
